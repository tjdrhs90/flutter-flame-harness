    await shot(tester, '01_home');

    // Screen 2 — <Second key screen, e.g. character select, tutorial, shop>
    // TODO(generator): navigate to the second representative screen.
    // await tester.tap(find.byIcon(Icons.XXXX));
    // await wait(tester);
    // await shot(tester, '02_<screen_name>');
    // TODO(generator): navigate back if required.

    // Screen 3 — Gameplay
    // TODO(generator): tap the play/start button and let the game reach a
    // visually interesting state (countdown finished, enemies/obstacles
    // visible, score non-zero).
    // Example:
    //   await tester.tap(find.byIcon(Icons.play_arrow));
    //   await tester.pump(const Duration(milliseconds: 400));
    //   for (var i = 0; i < 12; i++) {
    //     await tester.pump(const Duration(milliseconds: 500));
