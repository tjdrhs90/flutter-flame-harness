/// Drives the game and captures store screenshots at the running device's
/// resolution. Run via:
///
///   flutter drive \
///     --driver=test_driver/integration_test.dart \
///     --target=integration_test/screenshots_test.dart \
///     -d DEVICE_ID \
///     --dart-define=SCREENSHOT_LOCALE=ko \
///     --dart-define=screenshots=true
///
/// Repeat with --dart-define=SCREENSHOT_LOCALE=en for the English set.
/// The --dart-define=screenshots=true flag tells the ad helper to suppress
/// all ad units during capture (no banner/interstitial/rewarded overlays).
///
/// iOS 6.7" iPhone simulator and Android phone emulator are the required
/// device sizes for store screenshot compliance.
void main() {
  final binding = IntegrationTestWidgetsFlutterBinding.ensureInitialized();

  /// Settle the frame then capture a named screenshot.
  ///
  /// Pumps a couple of real frames so [takeScreenshot] reflects the current
  /// composited surface. On Android the surface is converted to an image once
  /// up front (see [convertFlutterSurfaceToImage] below) — converting again
  /// here would trigger an assertion.
  Future<void> shot(WidgetTester tester, String name) async {
    await tester.pump();
    await tester.pump(const Duration(milliseconds: 400));
    await tester.pump();
    await binding.takeScreenshot(name);
  }

  /// Settle without [pumpAndSettle] — avoid timing out on looping animations.
  Future<void> wait(WidgetTester tester, [int ms = 900]) async {
    await tester.pump(const Duration(milliseconds: 300));
    await tester.pump(Duration(milliseconds: ms));
  }

  testWidgets('capture store screenshots', (tester) async {
    // Locale for this capture run, injected via --dart-define=SCREENSHOT_LOCALE=ko|en.
    // (Platform.environment reflects the host, not the device — use fromEnvironment.)
    const locale = String.fromEnvironment(
      'SCREENSHOT_LOCALE',
      defaultValue: 'ko',
    );

    // TODO(generator): seed any SharedPreferences / Hive / Isar mock data that
    // avoids the first-run tutorial and displays a representative UI state
