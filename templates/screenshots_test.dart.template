    // Example:
    //   SharedPreferences.setMockInitialValues({...});

    app.main();

    // Generous warm-up so the first composited frame is ready.
    await wait(tester, 1500);
    await wait(tester, 1000);

    // TODO(generator): force the app locale to `locale` using the game's
    // locale controller / provider so screenshots are language-deterministic
    // regardless of the simulator's system locale.
    // Example:
    //   localeController.value = locale == 'en'
    //       ? const Locale('en')
    //       : const Locale('ko');
    await wait(tester, 700);

    // Android: convert the render surface to an image ONCE so takeScreenshot
    // works. Widget-tree taps still dispatch normally; the image re-renders as
    // we navigate.
    if (Platform.isAndroid) {
      await binding.convertFlutterSurfaceToImage();
      await tester.pump();
    }

    // -------------------------------------------------------------------------
    // Placeholder screen list — replace with the game's real screens.
